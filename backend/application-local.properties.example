# [DEPRECATED] Ưu tiên dùng backend/.env (xem .env.example).
# File này chỉ còn để override tùy chọn qua:
#   spring.config.import=optional:classpath:application-local.properties
#
# Sao chép thành src/main/resources/application-local.properties nếu vẫn cần.
# KHÔNG commit application-local.properties.

# --- Gmail (nếu không đặt trong .env) ---
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# spring.mail.username=${MAIL_USERNAME}
# spring.mail.password=${MAIL_PASSWORD}

# --- VNPay IPN / QR: URL public HTTPS (ngrok / cloudflare) ---
# 1. Chạy backend port 8080
# 2. Tunnel: ngrok http 8080  hoặc  cloudflared tunnel --url http://localhost:8080
# 3. Đặt trong .env:
#    VNPAY_RETURN_URL=https://YOUR_PUBLIC_HOST/api/payments/vnpay/callback
#    VNPAY_IPN_URL=https://YOUR_PUBLIC_HOST/api/payments/vnpay/ipn
#    VNPAY_FRONTEND_RETURN_URL=https://YOUR_PUBLIC_HOST/dat-hang
# 4. Khai báo IPN trên cổng merchant sandbox VNPay
# 5. Restart backend và tạo lại mã QR
